#!/usr/bin/env bash
# Shell wrapper for soma-upgrade-prerequisites.
# Resolves symlinks to find the project root, then invokes via .venv.

set -euo pipefail

SCRIPT_PATH="$(realpath "$0")"
PROJECT_ROOT="$(dirname "$(dirname "$SCRIPT_PATH")")"

VENV_PYTHON="${PROJECT_ROOT}/.venv/bin/python"
if [ ! -x "$VENV_PYTHON" ]; then
    echo "Error: virtual environment not found at ${PROJECT_ROOT}/.venv/" >&2
    echo "Run: cd ${PROJECT_ROOT} && uv venv && uv pip install -e '.[dev]'" >&2
    exit 1
fi
exec "$VENV_PYTHON" -m soma_upgrade_prerequisites "$@"
