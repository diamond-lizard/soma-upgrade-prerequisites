#!/usr/bin/env bash
# Shell wrapper for soma-upgrade-prerequisites.
# Resolves symlinks to find the project root, then invokes via uv run.

set -euo pipefail

SCRIPT_PATH="$(realpath "$0")"
PROJECT_ROOT="$(dirname "$(dirname "$SCRIPT_PATH")")"

exec uv run --project "$PROJECT_ROOT" python -m soma_upgrade_prerequisites "$@"
